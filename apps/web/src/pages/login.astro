---
import Layout from '../layouts/Layout.astro';

const apiUrl = import.meta.env.PUBLIC_API_URL;
const githubStartUrl = `${apiUrl}/api/auth/github/start`;
---

<Layout title="Sign in — jlog">
  <main
    style="
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: var(--space-6);
    "
  >
    <div
      style="
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: var(--radius-xl);
        padding: var(--space-12) var(--space-8);
        width: 100%;
        max-width: 400px;
        text-align: center;
        box-shadow: var(--shadow-lg);
      "
    >
      <h1
        style="
          font-size: var(--text-2xl);
          font-weight: 700;
          color: var(--color-text-primary);
          margin-bottom: var(--space-2);
          letter-spacing: -0.02em;
        "
      >
        jlog
      </h1>
      <p
        style="
          font-size: var(--text-sm);
          color: var(--color-text-secondary);
          margin-bottom: var(--space-8);
        "
      >
        Track your job applications — open source &amp; self-hostable.
      </p>

      <a
        href={githubStartUrl}
        style="
          display: inline-flex;
          align-items: center;
          justify-content: center;
          gap: var(--space-3);
          background: var(--color-accent);
          color: #ffffff;
          font-size: var(--text-sm);
          font-weight: 600;
          text-decoration: none;
          padding: var(--space-3) var(--space-6);
          border-radius: var(--radius-md);
          width: 100%;
          transition: background var(--transition-fast);
        "
        onmouseover="this.style.background='var(--color-accent-hover)'"
        onmouseout="this.style.background='var(--color-accent)'"
      >
        <!-- GitHub mark SVG — inline to avoid extra network request -->
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="currentColor"
          aria-hidden="true"
        >
          <path
            d="M12 0C5.37 0 0 5.373 0 12c0 5.303 3.438 9.8 8.207 11.387.6.113.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"
          ></path>
        </svg>
        Continue with GitHub
      </a>
    </div>
  </main>
</Layout>
