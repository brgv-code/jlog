---
import Layout from '../layouts/Layout.astro';
---

<Layout title="jlog — Track every application. Land the right job.">
  <div class="page">

    <!-- Nav -->
    <header class="nav">
      <span class="wordmark">jlog</span>
      <div class="nav-actions">
        <a href="/login" class="btn-ghost">Sign in</a>
        <a href="/login" class="btn-primary">Get started free</a>
      </div>
    </header>

    <!-- Hero -->
    <section class="hero">
      <h1 class="headline">Track every application.<br />Land the right job.</h1>
      <p class="subheading">
        jlog is an open-source job tracker with a Chrome extension that auto-captures
        applications from LinkedIn, Wellfound, and more.
      </p>
      <div class="cta-row">
        <a href="/login" class="btn-primary btn-lg">Get started free</a>
        <a href="https://github.com/brgv-code/jlog" class="btn-ghost btn-lg" target="_blank" rel="noopener noreferrer">
          View on GitHub
        </a>
      </div>

      <!-- Mock dashboard -->
      <div class="mock-dashboard" aria-hidden="true">
        <div class="mock-toolbar">
          <span class="mock-pill active">All</span>
          <span class="mock-pill">Applied</span>
          <span class="mock-pill">Interviewing</span>
          <span class="mock-pill">Offer</span>
          <span class="mock-search">Search company or role…</span>
        </div>
        <div class="mock-table">
          <div class="mock-row mock-row-header">
            <span>Company</span><span>Role</span><span>Status</span><span>Added</span>
          </div>
          <div class="mock-row">
            <span class="mock-company">Stripe</span>
            <span>Software Engineer, Infra</span>
            <span><span class="mock-badge interviewing">Interviewing</span></span>
            <span class="mock-muted">May 14, 2026</span>
          </div>
          <div class="mock-row mock-selected">
            <span class="mock-company">Linear</span>
            <span>Frontend Engineer</span>
            <span><span class="mock-badge applied">Applied</span></span>
            <span class="mock-muted">May 12, 2026</span>
          </div>
          <div class="mock-row">
            <span class="mock-company">Vercel</span>
            <span>Staff Engineer</span>
            <span><span class="mock-badge offer">Offer</span></span>
            <span class="mock-muted">May 10, 2026</span>
          </div>
          <div class="mock-row">
            <span class="mock-company">Figma</span>
            <span>Product Engineer</span>
            <span><span class="mock-badge saved">Saved</span></span>
            <span class="mock-muted">May 8, 2026</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Features -->
    <section class="features">
      <div class="features-grid">
        <div class="feature-card">
          <div class="feature-icon">⚡</div>
          <h3 class="feature-title">Auto-capture</h3>
          <p class="feature-desc">
            Extension detects applications on LinkedIn, Wellfound, Ashby, and more — no copy-pasting required.
          </p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">📋</div>
          <h3 class="feature-title">One dashboard</h3>
          <p class="feature-desc">
            Track status, notes, and timeline for every application in one place with full keyboard navigation.
          </p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">🤖</div>
          <h3 class="feature-title">Bring your AI</h3>
          <p class="feature-desc">
            Use Anthropic, OpenAI, Gemini, or local Ollama to extract job details and summarise listings.
          </p>
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class="footer">
      <p>jlog is open source. MIT licensed.</p>
      <a href="https://github.com/brgv-code/jlog" target="_blank" rel="noopener noreferrer" class="footer-link">
        GitHub →
      </a>
    </footer>

  </div>
</Layout>

<style>
  .page {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    background: var(--color-bg);
    color: var(--color-text-primary);
    font-family: var(--font-sans);
  }

  /* Nav */
  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 var(--space-8);
    height: 56px;
    border-bottom: 1px solid var(--color-border);
    background: var(--color-surface);
  }

  .wordmark {
    font-weight: 700;
    font-size: var(--text-lg);
    letter-spacing: -0.02em;
    color: var(--color-text-primary);
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  /* Buttons */
  .btn-primary {
    background: var(--color-accent);
    color: #fff;
    border: none;
    border-radius: var(--radius-md);
    padding: 6px 16px;
    font-size: var(--text-sm);
    font-family: var(--font-sans);
    text-decoration: none;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
  }

  .btn-primary:hover {
    background: var(--color-accent-hover);
  }

  .btn-ghost {
    background: none;
    color: var(--color-text-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 6px 16px;
    font-size: var(--text-sm);
    font-family: var(--font-sans);
    text-decoration: none;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
  }

  .btn-ghost:hover {
    border-color: var(--color-border-strong);
    color: var(--color-text-primary);
  }

  .btn-lg {
    padding: 10px 24px;
    font-size: var(--text-base);
  }

  /* Hero */
  .hero {
    padding: var(--space-16) var(--space-8) var(--space-12);
    max-width: 860px;
    margin: 0 auto;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .headline {
    font-size: var(--text-4xl);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.15;
    color: var(--color-text-primary);
    margin-bottom: var(--space-6);
  }

  .subheading {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    max-width: 560px;
    line-height: 1.6;
    margin-bottom: var(--space-8);
  }

  .cta-row {
    display: flex;
    gap: var(--space-3);
    margin-bottom: var(--space-12);
  }

  /* Mock dashboard */
  .mock-dashboard {
    width: 100%;
    max-width: 720px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .mock-toolbar {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-4);
    border-bottom: 1px solid var(--color-border);
    flex-wrap: wrap;
  }

  .mock-pill {
    background: none;
    border: 1px solid transparent;
    border-radius: var(--radius-md);
    color: var(--color-text-secondary);
    font-size: var(--text-xs);
    padding: 3px 10px;
  }

  .mock-pill.active {
    background: var(--color-surface-raised);
    border-color: var(--color-border);
    color: var(--color-text-primary);
  }

  .mock-search {
    margin-left: auto;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    color: var(--color-text-tertiary);
    font-size: var(--text-xs);
    padding: 3px 10px;
  }

  .mock-table {
    width: 100%;
  }

  .mock-row {
    display: grid;
    grid-template-columns: 1fr 2fr 1fr 1fr;
    padding: var(--space-3) var(--space-4);
    border-bottom: 1px solid var(--color-border);
    font-size: var(--text-sm);
    align-items: center;
    gap: var(--space-4);
  }

  .mock-row:last-child {
    border-bottom: none;
  }

  .mock-row-header {
    color: var(--color-text-secondary);
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    background: var(--color-bg);
  }

  .mock-selected {
    background: var(--color-surface-raised);
  }

  .mock-company {
    font-weight: 600;
    color: var(--color-text-primary);
  }

  .mock-muted {
    color: var(--color-text-tertiary);
    font-size: var(--text-xs);
  }

  .mock-badge {
    display: inline-block;
    padding: 2px 8px;
    border-radius: var(--radius-full);
    font-size: var(--text-xs);
    font-weight: 500;
  }

  .mock-badge.applied {
    background: rgba(94, 106, 210, 0.15);
    color: #818cf8;
  }

  .mock-badge.interviewing {
    background: rgba(251, 191, 36, 0.12);
    color: #fbbf24;
  }

  .mock-badge.offer {
    background: rgba(48, 209, 88, 0.12);
    color: #34d399;
  }

  .mock-badge.saved {
    background: rgba(144, 144, 168, 0.12);
    color: var(--color-text-secondary);
  }

  /* Features */
  .features {
    padding: var(--space-12) var(--space-8);
    max-width: 960px;
    margin: 0 auto;
    width: 100%;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
  }

  @media (max-width: 640px) {
    .features-grid {
      grid-template-columns: 1fr;
    }
    .headline {
      font-size: var(--text-3xl);
    }
  }

  .feature-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
  }

  .feature-icon {
    font-size: var(--text-2xl);
    margin-bottom: var(--space-3);
    line-height: 1;
  }

  .feature-title {
    font-size: var(--text-base);
    font-weight: 600;
    margin-bottom: var(--space-2);
    color: var(--color-text-primary);
  }

  .feature-desc {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: 1.6;
  }

  /* Footer */
  .footer {
    margin-top: auto;
    padding: var(--space-8);
    border-top: 1px solid var(--color-border);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-6);
    font-size: var(--text-sm);
    color: var(--color-text-tertiary);
  }

  .footer-link {
    color: var(--color-text-secondary);
    text-decoration: none;
  }

  .footer-link:hover {
    color: var(--color-text-primary);
  }
</style>
